# Build artifacts and deps — rebuilt inside the image
frontend/node_modules
frontend/dist

# Python caches and local SQLite DB
**/__pycache__
**/*.pyc
backend/sensorwatch.db
backend/*.db

# VCS / editor / OS noise
.git
.gitignore
.DS_Store
*.log

# Per-service Dockerfiles (root Dockerfile is the one used for all-in-one deploy)
frontend/Dockerfile
backend/Dockerfile
